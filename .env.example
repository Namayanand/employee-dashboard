# Local dev default is a SQLite file under data/. Override for prod:
DATABASE_URL=sqlite:///./data/employees.db
# Turso    : sqlite+libsql://<db>.turso.io?authToken=<token>&secure=true
# Postgres : postgresql+psycopg2://user:pass@host:5432/dbname

DEFAULT_PAGE_SIZE=50
INGEST_CHUNK_SIZE=10000
MAX_SPLIT_GROUPS=500
